---
interface Props {
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted";
  class?: string;
  [x: string]: any;
}

const {
  size = "md",
  style = "primary",
  block,
  class: className,
  ...rest
} = Astro.props;

const sizes: Record<"md" | "lg", string> = {
  md: "px-5 py-2.5",
  lg: "px-6 py-3",
};

const styles: Record<"outline" | "primary" | "inverted", string> = {
  outline:
    "border-2 border-black text-black hover:bg-black hover:text-white",

  primary:
    "bg-black text-white border-2 border-transparent hover:bg-slate-900",

  inverted:
    "bg-white text-black border-2 border-transparent hover:bg-slate-100",
};
---

<button
  {...rest}
  class:list={[
    "rounded-sm text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
>
  <slot />
</button>