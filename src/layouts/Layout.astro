---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/colors.css";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const siteName = "Optima Finance Счетоводство";
const defaultDescription =
  "Optima Finance – Професионално счетоводно обслужване на фирми. Предлагаме цялостни счетоводни услуги,\
   ТРЗ, ДДС, данъчни консултации и финансови анализи за бизнеса. Оптимизирайте разходите си с индивидуален\
    подход, лоялност и сигурност. Доверете се на вашия надежден партньор в бизнеса!";

const { title, description } = Astro.props;

const pageTitle = title
  ? `${title} | ${siteName}`
  : `${siteName} - Регистрация на фирми`;

const pageDescription = description || defaultDescription;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const ogImage = new URL("/opengraph.jpg", Astro.site).toString();
---

<!doctype html>
<html lang="bg">
  <head>

    <!-- Да се премахне при хостване на сайта на неговия домейн -->
    <meta name="robots" content="noindex, nofollow" />
    <!-- Да се премахне при хостване на сайта на неговия домейн -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Основни SEO тагове -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- Open Graph (Facebook, LinkedIn, Viber и др.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta
      property="og:image:alt"
      content="Превю изображение на Astroship сайта"
    />
    <meta property="og:locale" content="bg_BG" />

    <!-- Twitter / X cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@web3templates" />

    <!-- Astro SEO компонент (по желание, но вече не е задължителен) -->
    <SEO
      title={pageTitle}
      description={pageDescription}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          type: "website",
          title: pageTitle,
          url: canonicalURL,
          image: ogImage,
        },
        image: {
          alt: "Превю изображение на сайта",
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@web3templates",
      }}
    />
  </head>

  <body class="bg-background-page">
    <Navbar />
    <p class="text-error text-center">Please remove the 'No robot' line and this line from the layout once final hosting is done. It is currently under construction!!!</p>
    <main>
      <slot />
    </main>
    <Footer />

    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
