---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Контакти</Fragment>
      <Fragment slot="desc"
        >Свържете се с нас, ние сме тук за да помогнем!</Fragment
      >
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>       
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-neutral-600">
            <Icon class="text-neutral-400 w-4 h-4" name="uil:map-marker" />
            <span>Пловдив 4000</span>
          </div><div class="flex items-center mt-2 space-x-2 text-neutral-600">
            <Icon class="text-neutral-400 w-4 h-4" name="uil:envelope" /><a
              href="mailto:hello@astroshipstarter.com"
              >Mail@optimafinance.eu</a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-neutral-600">
            <Icon class="text-neutral-400 w-4 h-4" name="uil:phone" /><a
              href="tel:+1 (987) 4587 899">+359 878 000 000</a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform />
      </div>
    </div>
  </Container>
</Layout>
